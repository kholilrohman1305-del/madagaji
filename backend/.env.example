PORT=4000
NODE_ENV=production

DB_HOST=127.0.0.1
DB_PORT=3306
DB_POOL_SIZE=20
DB_CONNECT_TIMEOUT=10000

# DB utama (gaji)
DB1_NAME=u383143089_gaji
DB1_USER=u383143089_gaji
DB1_PASSWORD=ISI_PASSWORD_GAJI

# DB master (pddata)
DB2_NAME=u383143089_pddata
DB2_USER=u383143089_pddata
DB2_PASSWORD=ISI_PASSWORD_PDDATA

FRONTEND_ORIGIN=http://localhost:5173,https://your-domain.com
ENABLE_SYSTEM_GATEWAY=true
PDMADA_FRONTEND_DIST_DIR=../apps/pdmada/frontend/dist

# SKS DB (opsional; fallback ke DB1)
SKS_DB_HOST=127.0.0.1
SKS_DB_PORT=3306
SKS_DB_USER=
SKS_DB_PASS=
SKS_DB_NAME=
SKS_DB_POOL_SIZE=10

# PDMADA DB (opsional; fallback ke DB1)
PDMADA_DB_HOST=127.0.0.1
PDMADA_DB_PORT=3306
PDMADA_DB_USER=
PDMADA_DB_PASSWORD=
PDMADA_DB_NAME=
PDMADA_DB_POOL_SIZE=10

JWT_SECRET=ganti_dengan_secret_aman
JWT_EXPIRES_IN=7d
JWT_ISSUER=mada-core
JWT_AUDIENCE=mada-apps

ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
ADMIN_NAME=Administrator
AUTH_BYPASS=false
AUTH_TRUST_TOKEN_USER=false

HTTP_COMPRESSION_LEVEL=6
HTTP_LOG=false
HTTP_KEEP_ALIVE_TIMEOUT_MS=65000
HTTP_HEADERS_TIMEOUT_MS=66000
HTTP_REQUEST_TIMEOUT_MS=120000
